---
import { Icon } from 'astro-icon/components';

// 3-column comparison table matching Slide 3 reference.
const rows = [
  'Captación',
  'Evaluación',
  'Contrato',
  'Seguimiento',
  'Mantenim.',
  'Cobranza',
  'Renovación',
  'Entrega',
  'Cierre',
];

const columns = [
  {
    label: 'Inmobiliaria tradicional',
    checks: [true, true, true, false, false, false, false, false, false],
  },
  {
    label: 'Administrador',
    checks: [true, false, true, true, true, true, false, false, true],
  },
  {
    label: 'ANCORA',
    checks: [true, true, true, true, true, true, true, true, true],
  },
];
---

<div class="overflow-x-auto">
  <table class="table-fixed w-full min-w-[600px] border-collapse text-sm">
    <colgroup>
      <col class="w-[28%]" />
      <col class="w-[24%]" />
      <col class="w-[24%]" />
      <col class="w-[24%]" />
    </colgroup>
    <thead>
      <tr>
        <th scope="col" class="border-b border-neutral-200 py-3 text-left font-normal text-neutral-500"></th>
        {columns.map((col, ci) => (
          <th
            scope="col"
            class:list={[
              'border-b border-neutral-200 px-2 py-3 text-center text-sm font-semibold leading-snug text-primary-600',
              ci === columns.length - 1 && 'bg-accent-50 border-x border-accent-200',
            ]}
          >
            {col.label}
          </th>
        ))}
      </tr>
    </thead>
    <tbody class="divide-y divide-neutral-100">
      {rows.map((row, ri) => (
        <tr>
          <th scope="row" class="py-3 pr-3 text-left font-normal text-neutral-700">{row}</th>
          {columns.map((col, ci) => (
            <td
              class:list={[
                'px-3 py-3 text-center',
                ci === columns.length - 1 && 'bg-accent-50 border-x border-accent-200',
              ]}
            >
              {col.checks[ri] ? (
                <Icon name="ph:check-circle" class="mx-auto size-5 text-accent-500" aria-label="Incluido" />
              ) : (
                <span class="sr-only">No incluido</span>
              )}
            </td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>

<p class="mt-6 text-sm text-neutral-600">
  Muchas inmobiliarias terminan su trabajo cuando se firma el contrato. ANCORA continúa administrando durante toda la relación contractual.
</p>
