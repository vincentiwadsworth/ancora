---
// HeroVisual.astro — Inline SVG decorative pattern derived from ANCORA logo geometry.
// Logo mark: diagonal X (M16 16 L48 48 M48 16 L16 48).
// Desktop: repeating cross-pattern grid with accent/primary colour.
// Mobile: single oversized faint cross behind text.
// aria-hidden="true" — purely decorative.
---

<svg
  aria-hidden="true"
  class="hero-visual pointer-events-none h-full w-full"
  viewBox="0 0 600 480"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <!-- Cross mark from logo geometry -->
    <g id="cross-mark">
      <line x1="3" y1="3" x2="12" y2="12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
      <line x1="12" y1="3" x2="3" y2="12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
    </g>
    <!-- Larger cross mark (used standalone on mobile) -->
    <g id="cross-mark-lg">
      <line x1="0" y1="0" x2="120" y2="120" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      <line x1="120" y1="0" x2="0" y2="120" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </g>
    <!-- Repeating grid pattern -->
    <pattern id="cross-grid" x="0" y="0" width="54" height="54" patternUnits="userSpaceOnUse">
      <use href="#cross-mark" x="3" y="3" class="text-primary-600" opacity="0.08" />
      <use href="#cross-mark" x="30" y="3" class="text-accent-500" opacity="0.06" />
      <use href="#cross-mark" x="3" y="30" class="text-accent-500" opacity="0.06" />
      <use href="#cross-mark" x="30" y="30" class="text-primary-600" opacity="0.08" />
    </pattern>
  </defs>

  <!-- Mobile: single large faint cross, centered -->
  <g class="hero-visual-mobile">
    <use href="#cross-mark-lg" x="240" y="180" class="text-primary-600" opacity="0.06" />
  </g>

  <!-- Desktop: full grid pattern -->
  <g class="hero-visual-desktop">
    <rect x="0" y="0" width="600" height="480" fill="url(#cross-grid)" />
    <!-- Accent colour crosses at larger scale for visual depth -->
    <g class="text-accent-500">
      <use href="#cross-mark-lg" x="420" y="40" opacity="0.1" />
      <use href="#cross-mark-lg" x="300" y="280" opacity="0.08" />
      <use href="#cross-mark-lg" x="460" y="320" opacity="0.06" />
    </g>
    <!-- Primary colour crosses at larger scale -->
    <g class="text-primary-600">
      <use href="#cross-mark-lg" x="60" y="300" opacity="0.06" />
      <use href="#cross-mark-lg" x="180" y="60" opacity="0.08" />
      <use href="#cross-mark-lg" x="500" y="180" opacity="0.06" />
    </g>
  </g>
</svg>

<style>
  .hero-visual {
    max-height: 480px;
  }
  .hero-visual-mobile {
    display: block;
  }
  .hero-visual-desktop {
    display: none;
  }
  @media (width >= 48rem) {
    .hero-visual-mobile {
      display: none;
    }
    .hero-visual-desktop {
      display: block;
    }
  }
</style>
