---
import { Icon } from 'astro-icon/components';

// Monthly report example card matching Slide 3 reference.
const photoSrc = `${import.meta.env.BASE_URL}/images/report-interior.webp`;
const photoFallback = `${import.meta.env.BASE_URL}/images/report-interior.svg`;

const labels = [
  { icon: 'receipt', text: 'Comprobantes adjuntos' },
  { icon: 'list-checks', text: 'Estado de pagos del mes' },
  { icon: 'clipboard-text', text: 'Reporte de novedades y mantenimientos' },
  { icon: 'camera', text: 'Registro fotográfico del inmueble' },
];
---

<figure class="overflow-hidden rounded-xl border border-neutral-200 bg-white">
  <img
    src={photoSrc}
    alt="Interior del inmueble administrado por ANCORA"
    width="600"
    height="400"
    loading="lazy"
    class="aspect-[3/2] w-full object-cover"
    onerror={`this.onerror=null;this.src='${photoFallback}';`}
  />
  <figcaption class="p-6">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-primary-600">
      Reporte mensual de ejemplo
    </h3>

    <table class="mt-5 w-full text-sm">
      <tbody class="divide-y divide-neutral-200">
        <tr>
          <th scope="row" class="py-2 text-left font-normal text-neutral-600">Período</th>
          <td class="py-2 text-right font-semibold text-primary-600">Junio 2026</td>
        </tr>
        <tr>
          <th scope="row" class="py-2 text-left font-normal text-neutral-600">Inmueble</th>
          <td class="py-2 text-right font-semibold text-primary-600">Equipetrol — Torre X, Piso 8</td>
        </tr>
        <tr>
          <th scope="row" class="py-2 text-left font-normal text-neutral-600">Estado</th>
          <td class="py-2 text-right font-semibold text-primary-600">Ocupado</td>
        </tr>
        <tr>
          <th scope="row" class="py-2 text-left font-normal text-neutral-600">Canon cobrado</th>
          <td class="py-2 text-right font-semibold text-primary-600">Bs. 3.000</td>
        </tr>
        <tr>
          <th scope="row" class="py-2 text-left font-normal text-neutral-600">Fee ANCORA (7%)</th>
          <td class="py-2 text-right font-semibold text-neutral-500">– Bs. 210</td>
        </tr>
        <tr>
          <th scope="row" class="py-2 text-left font-semibold text-primary-600">Neto transferido</th>
          <td class="py-2 text-right text-base font-bold text-success-500">Bs. 2.790</td>
        </tr>
        <tr>
          <th scope="row" class="py-2 text-left font-normal text-neutral-600">Fecha transferencia</th>
          <td class="py-2 text-right font-semibold text-primary-600">10/06/2026</td>
        </tr>
      </tbody>
    </table>

    <ul class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-4">
      {labels.map((item) => (
        <li class="flex flex-col items-center gap-2 text-center text-xs text-neutral-600">
          <Icon name={`ph:${item.icon}`} class="size-6 text-accent-500" aria-hidden="true" />
          <span>{item.text}</span>
        </li>
      ))}
    </ul>
  </figcaption>
</figure>
