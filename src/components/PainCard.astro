---
import { Icon } from 'astro-icon/components';
import type { Pain } from '../data/pains';

interface Props {
  pain: Pain;
}

const { pain } = Astro.props;
---

<article class="rounded-lg border border-neutral-200 bg-white p-6">
  <div class="text-accent-500" aria-hidden="true">
    <Icon name={`ph:${pain.icon}`} class="text-2xl" />
  </div>
  <h3 class="mt-4 text-xl font-semibold text-primary-600">
    {pain.title}
  </h3>
  <p class="mt-3 text-base text-neutral-600">
    {pain.description}
  </p>
</article>
