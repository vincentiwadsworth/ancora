---
import type { Pillar } from '../data/pillars';

interface Props {
  pillar: Pillar;
}

const { pillar } = Astro.props;
---

<article class="rounded-lg border border-neutral-200 bg-white p-6">
  <h3 class="text-xl font-semibold text-primary-600">
    {pillar.title}
  </h3>
  <p class="mt-3 text-base text-neutral-600">
    {pillar.description}
  </p>
</article>
