---
// ProcessCycle.astro
// Circular 7-step administration cycle matching Slide 2 reference.
// Desktop: SVG diagram. Mobile: linear ordered list fallback.
// SVG colors use CSS custom properties — they track @theme tokens automatically.

const steps = [
  { label: 'Captar y filtrar clientes', gold: true },
  { label: 'Gestión contractual', gold: true },
  { label: 'Comunicación con inquilinos', gold: false },
  { label: 'Cobranzas', gold: true },
  { label: 'Mantenimientos y reparaciones', gold: false },
  { label: 'Reportar resultados', gold: false },
  { label: 'Gestionar fin del contrato', gold: false },
];

const CENTER = 200;
const NODE_R = 124;
const BADGE_R = 26;
const LABEL_R = 168;
const SLICE = 360 / steps.length;

const nodes = steps.map((step, i) => {
  const deg = -90 + i * SLICE;
  const rad = (deg * Math.PI) / 180;
  return {
    ...step,
    n: i + 1,
    x: CENTER + NODE_R * Math.cos(rad),
    y: CENTER + NODE_R * Math.sin(rad),
    lx: CENTER + LABEL_R * Math.cos(rad),
    ly: CENTER + LABEL_R * Math.sin(rad),
  };
});
---

{/* Mobile fallback */}
<ol class="mx-auto max-w-md space-y-3 md:hidden">
  {nodes.map((node) => (
    <li class="flex items-center gap-3 rounded-lg border border-neutral-200 bg-white p-3">
      <span
        class:list={[
          'flex h-9 w-9 flex-none items-center justify-center rounded-full text-sm font-semibold text-white',
          node.gold ? 'bg-accent-500' : 'bg-primary-600',
        ]}
      >
        {node.n}
      </span>
      <span class="text-sm font-semibold text-primary-600">{node.label}</span>
    </li>
  ))}
</ol>

{/* Desktop circular SVG — colors via CSS variables, not hardcoded hex */}
<div class="hidden px-4 md:block cycle-ring cycle-spoke cycle-ink cycle-muted cycle-gold cycle-navy cycle-white cycle-sans cycle-display">
  <svg
    viewBox="0 0 400 400"
    role="img"
    aria-label="Ciclo de administración ANCORA: Captar y filtrar clientes, Gestión contractual, Comunicación con inquilinos, Cobranzas, Mantenimientos y reparaciones, Reportar resultados, Gestionar fin del contrato."
    class="mx-auto w-full max-w-lg"
    style="overflow: visible;"
  >
    <circle cx={CENTER} cy={CENTER} r={NODE_R} fill="none" stroke="var(--cycle-ring)" stroke-width="2" />

    {nodes.map((node) => (
      <line x1={CENTER} y1={CENTER} x2={node.x} y2={node.y} stroke="var(--cycle-spoke)" stroke-width="2" />
    ))}

    <circle cx={CENTER} cy={CENTER} r="52" fill="var(--cycle-white)" stroke="var(--cycle-ink)" stroke-width="2" />
    <text
      x={CENTER}
      y={CENTER - 4}
      text-anchor="middle"
      font-family="var(--cycle-display)"
      font-size="18"
      font-weight="700"
      letter-spacing="0.06em"
      fill="var(--cycle-ink)"
    >
      ANCORA
    </text>
    <text
      x={CENTER}
      y={CENTER + 16}
      text-anchor="middle"
      font-family="var(--cycle-sans)"
      font-size="8"
      fill="var(--cycle-muted)"
    >
      Administramos. Vos descansás.
    </text>

    {nodes.map((node) => (
      <g>
        <circle cx={node.x} cy={node.y} r={BADGE_R} fill={node.gold ? 'var(--cycle-gold)' : 'var(--cycle-navy)'} />
        <text
          x={node.x}
          y={node.y + 5}
          text-anchor="middle"
          font-family="var(--cycle-sans)"
          font-size="16"
          font-weight="700"
          fill="var(--cycle-white)"
        >
          {node.n}
        </text>
        <text
          x={node.lx}
          y={node.ly + 4}
          text-anchor="middle"
          font-family="var(--cycle-sans)"
          font-size="12"
          font-weight="600"
          fill="var(--cycle-ink)"
        >
          {node.label}
        </text>
      </g>
    ))}
  </svg>
</div>

<style>
  .cycle-ring { --cycle-ring: var(--color-neutral-200); }
  .cycle-spoke { --cycle-spoke: var(--color-neutral-100); }
  .cycle-ink { --cycle-ink: var(--color-primary-600); }
  .cycle-muted { --cycle-muted: var(--color-neutral-500); }
  .cycle-gold { --cycle-gold: var(--color-accent-500); }
  .cycle-navy { --cycle-navy: var(--color-primary-600); }
  .cycle-white { --cycle-white: #ffffff; }
  .cycle-sans { --cycle-sans: "Inter", system-ui, -apple-system, sans-serif; }
  .cycle-display { --cycle-display: "Cormorant Garamond", "Georgia", "Times New Roman", serif; }
</style>
