---
import type { ProcessStepData } from '../data/tenantSelectionSteps';

interface Props {
  step: ProcessStepData;
}

const { step } = Astro.props;
---

<article class="flex gap-6">
  <div class="flex flex-col items-center">
    <div class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-primary-600 text-lg font-semibold text-white">
      {String(step.step).padStart(2, '0')}
    </div>
    <div class="mt-2 w-px flex-1 bg-neutral-200" aria-hidden="true"></div>
  </div>
  <div class="pb-10">
    <h3 class="text-xl font-semibold text-primary-600">
      {step.title}
    </h3>
    <p class="mt-2 text-base text-neutral-600">
      {step.description}
    </p>
  </div>
</article>
