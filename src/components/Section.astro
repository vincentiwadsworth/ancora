---
interface Props {
  id?: string;
  heading?: string;
  headingClass?: string;
  intro?: string;
  as?: 'section' | 'div' | 'article' | 'aside';
  containerClass?: string;
  background?: 'default' | 'muted' | 'inverse';
  padding?: 'compact' | 'default' | 'spacious';
}

const {
  id,
  heading,
  headingClass = '',
  intro,
  as: Tag = 'section',
  containerClass = '',
  background = 'default',
  padding = 'default',
} = Astro.props;

const headingId = id && heading ? `${id}-heading` : undefined;

const bgClasses = {
  default: 'bg-surface',
  muted: 'bg-surface-muted',
  inverse: 'bg-primary-600 text-white',
}[background];

const paddingClasses = {
  compact: 'py-[var(--spacing-section-y-sm)]',
  default: 'py-[var(--spacing-section-y)]',
  spacious: 'py-[var(--spacing-section-y-lg)]',
}[padding];
---

<Tag
  id={id}
  aria-labelledby={headingId}
  class:list={['scroll-mt-20', paddingClasses, bgClasses, containerClass]}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {(heading || intro) && (
      <div class="mb-12 max-w-3xl">
        {heading && (
          <h2
            id={headingId}
            class:list={[
              'mt-2 font-display text-3xl font-semibold leading-tight sm:text-4xl',
              headingClass,
            ]}
          >
            {heading}
          </h2>
        )}
        {intro && (
          <p class="mt-4 text-lg text-neutral-600">
            {intro}
          </p>
        )}
      </div>
    )}
    <slot />
  </div>
</Tag>
