---
import type { TeamMemberData } from '../data/team';

interface Props {
  member: TeamMemberData;
}

const { member } = Astro.props;
---

<article class="rounded-lg border border-neutral-200 bg-white p-8 text-center">
  <div
    class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-primary-600 text-2xl font-semibold text-white"
    aria-hidden="true"
  >
    {member.initials}
  </div>
  <h3 class="mt-6 text-xl font-semibold text-primary-600">
    {member.name}
  </h3>
  <p class="mt-2 text-sm font-semibold uppercase tracking-wider text-primary-600">
    {member.credentials}
  </p>
  <p class="mt-3 text-sm text-neutral-600">
    {member.education}
  </p>
  <p class="mt-3 text-sm italic text-neutral-500">
    {member.experience}
  </p>
</article>
