---
import { Icon } from 'astro-icon/components';

// REQ-1PH-001 — 3-item trust strip below the hero.
// Self-contained (no props): the three pillars are fixed business claims.
const items = [
  {
    icon: 'shield-check',
    label: 'Menos vacancia / Más ingresos',
  },
  {
    icon: 'gavel',
    label: 'Menos riesgo legal / Más protección',
  },
  {
    icon: 'clock',
    label: 'Menos tiempo invertido / Más tranquilidad',
  },
];
---

<div class="border-y border-neutral-200 bg-white py-6">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <ul class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between md:gap-8">
      {items.map((item) => (
        <li class="flex items-center gap-4 text-sm font-medium text-primary-600 md:justify-center md:flex-1 transition duration-300 hover:-translate-y-1 hover:shadow-lg">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent-50 text-accent-600">
            <Icon name={`ph:${item.icon}`} class="size-5" aria-hidden="true" />
          </div>
          <span class="leading-snug">{item.label}</span>
        </li>
      ))}
    </ul>
  </div>
</div>
