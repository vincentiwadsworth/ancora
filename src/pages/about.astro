---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import TeamMember from '../components/TeamMember.astro';
import PillarCard from '../components/PillarCard.astro';
import { team } from '../data/team';
import { pillars } from '../data/pillars';

const valuesExpanded: Record<string, string> = {
  Rentabilidad:
    'Trabajamos para reducir la vacancia y mantener tu inmueble ocupado con inquilinos calificados. Operamos con cobranza activa, contratos bajo escritura pública y reportes mensuales que te muestran exactamente cuánto ingresa y por qué.',
  Protección:
    'Cada paso queda documentado. Inspecciones iniciales con registro fotográfico firmado, contratos notarizados, seguimiento periódico, cotizaciones aprobadas por el propietario y conciliaciones al finalizar la relación contractual.',
  Tranquilidad:
    'Nos ocupamos de todo el día a día: buscar inquilinos, cobrar alquileres, coordinar técnicos, supervisar reparaciones, gestionar conflictos. Vos solo cobrás al final del mes, con la liquidación completa en la mano.',
};
---

<BaseLayout page="about">
  <Section
    id="introduccion"
    containerClass="!py-[var(--spacing-section-y-sm)]"
    background="default"
  >
    <div class="max-w-3xl">
      <h1 class="text-4xl font-bold leading-tight text-primary-600 sm:text-5xl">
        ¿Quiénes somos?
      </h1>
      <p class="mt-6 text-lg text-neutral-600 sm:text-xl">
        ANCORA nace con experiencia desde el primer día. Fundada por
        profesionales con formación en administración de empresas, ingeniería
        civil y gestión inmobiliaria, combinamos criterio operativo con
        sensibilidad patrimonial para administrar inmuebles residenciales en
        Bolivia.
      </p>
    </div>
  </Section>

  <Section
    id="equipo"
    heading="Nuestro equipo"
    intro="Las personas detrás de cada decisión operativa."
    background="muted"
  >
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      {team.map((member) => <TeamMember member={member} />)}
    </div>
  </Section>

  <Section
    id="valores"
    heading="Nuestros valores"
    intro="Tres compromisos que guían cada decisión que tomamos."
    background="default"
  >
    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {pillars.map((pillar) => (
        <PillarCard
          pillar={{
            title: pillar.title,
            description: valuesExpanded[pillar.title] ?? pillar.description,
          }}
        />
      ))}
    </div>
  </Section>
</BaseLayout>
