---
import { Icon } from 'astro-icon/components';
import ComparisonVisual from '../components/ComparisonVisual.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import MonthlyReport from '../components/MonthlyReport.astro';
import PainCard from '../components/PainCard.astro';
import PricingCard from '../components/PricingCard.astro';
import ProcessCycle from '../components/ProcessCycle.astro';
import Section from '../components/Section.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import { site, whatsappLink } from '../config/site';
import { pains } from '../data/pains';
import { services } from '../data/services';
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.brandName,
  url: 'https://ancora.com.bo',
  logo: 'https://ancora.com.bo/favicon.svg',
  description: site.tagline,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address,
    addressCountry: 'BO',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: site.phone,
      contactType: 'customer service',
      areaServed: 'BO',
      availableLanguage: ['Spanish'],
    },
  ],
  email: site.email,
};

// TODO: verify copy with client — answers are concise placeholders.
const faqItems = [
  {
    q: '¿Qué incluye la administración de ANCORA?',
    a: 'Captación y evaluación de inquilinos, contrato bajo escritura pública, cobranza activa, coordinación de mantenimientos y reporte mensual con liquidación.',
  },
  {
    q: '¿Cuánto cuesta el servicio?',
    a: 'Cobramos 7% del canon mensual. Sin alquiler cobrado, no hay fee de administración.',
  },
  {
    q: '¿Cómo eligen a los inquilinos?',
    a: 'Evaluamos documentación y antecedentes antes de recomendar un inquilino.',
  },
  {
    q: '¿Qué pasa si el inquilino no paga?',
    a: 'Gestionamos la cobranza desde el primer día de atraso, sin esperar a fin de mes.',
  },
  {
    q: '¿Cómo recibo mis ingresos?',
    a: 'Cada mes recibís un reporte con la liquidación detallada y la transferencia neta a tu cuenta.',
  },
  {
    q: '¿Qué pasa cuando finaliza el contrato?',
    a: 'Hacemos la inspección de entrega y la conciliación final de la relación contractual.',
  },
];

const ctaAsesoria = whatsappLink('solicitarAsesoria');
const ctaWhatsApp = whatsappLink('general');
const underlinedHeading =
  'uppercase tracking-wider underline decoration-accent-500 decoration-2 underline-offset-4';
---

<BaseLayout page="home" jsonLd={jsonLd}>
  {/* Hero */}
  {/* TODO(PR 4): add lifestyle background <img> overlay with text-safe gradient */}
  <Section id="hero" background="default" padding="spacious">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="font-display text-5xl font-bold leading-tight text-primary-600 sm:text-6xl">
        Tu propiedad genera renta.{' '}
        <span class="text-accent-500">Vos solo cobrás.</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-600 sm:text-xl">
        Administración profesional de propiedades residenciales en alquiler en Bolivia. Nos encargamos de todo para que tu inmueble genere rentabilidad.
      </p>
      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a
          href={ctaAsesoria}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-primary-600 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-primary-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-600"
        >
          <Icon name="ph:whatsapp-logo" aria-hidden="true" />
          Solicitar asesoría gratuita
        </a>
      </div>
      <TrustStrip />
    </div>
  </Section>

  {/* Dolores */}
  <Section
    id="dolores"
    heading="¿Compraste un inmueble para generar ingresos o para administrar problemas?"
    intro="Los problemas que enfrentás cuando administrás solo."
    background="muted"
  >
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {pains.map((pain) => <PainCard pain={pain} />)}
    </div>
    <p class="mt-10 text-base italic text-neutral-600">
      "La administración profesional cuesta menos que una mala administración."
    </p>
  </Section>

  {/* Cómo funciona */}
  <Section
    id="como-funciona"
    heading="¿Cómo funciona?"
    headingClass={underlinedHeading}
    intro="Un ciclo completo de administración, de la captación al cierre."
    background="default"
  >
    <ProcessCycle />
  </Section>

  {/* Servicios */}
  <Section
    id="servicios"
    heading="Servicios"
    headingClass={underlinedHeading}
    intro="Cobertura completa: desde la captación hasta la entrega del inmueble."
    background="muted"
  >
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          icon={service.icon}
        />
      ))}
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <MonthlyReport />
      <PricingCard />
    </div>
  </Section>

  {/* Diferenciación */}
  <Section
    id="diferenciacion"
    heading="La diferencia entre alquilar y administrar"
    intro="Inmobiliaria tradicional, administrador independiente y ANCORA, lado a lado."
    background="default"
  >
    <ComparisonVisual />
  </Section>

  {/* Preguntas frecuentes */}
  <Section
    id="preguntas"
    heading="Preguntas frecuentes"
    headingClass={underlinedHeading}
    intro="Respuestas a las dudas más comunes de los propietarios."
    background="muted"
  >
    <FaqAccordion items={faqItems} />
  </Section>

  {/* CTA final */}
  {/* TODO(PR 4): add building dusk background <img> overlay with gradient */}
  <Section id="cta-final" background="inverse" padding="spacious">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">
        Tu patrimonio merece administración profesional.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-neutral-200">
        Agendá una asesoría gratuita o escribinos por WhatsApp.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={ctaAsesoria}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-6 py-3 text-base font-semibold text-primary-600 transition-colors hover:bg-accent-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
        >
          <Icon name="ph:calendar-check" aria-hidden="true" />
          Agendar asesoría gratuita
        </a>
        <a
          href={ctaWhatsApp}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 rounded-md border border-neutral-300 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
        >
          <Icon name="ph:phone" aria-hidden="true" />
          Escribinos por WhatsApp
        </a>
      </div>
    </div>
  </Section>
</BaseLayout>
