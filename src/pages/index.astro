---
import { Icon } from 'astro-icon/components';
import ComparisonVisual from '../components/ComparisonVisual.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import MonthlyReport from '../components/MonthlyReport.astro';
import PainCard from '../components/PainCard.astro';
import PricingCard from '../components/PricingCard.astro';
import ProcessCycle from '../components/ProcessCycle.astro';
import Section from '../components/Section.astro';
import ServiceCard from '../components/ServiceCard.astro';
import TrustStrip from '../components/TrustStrip.astro';
import { site, whatsappLink } from '../config/site';
import { pains } from '../data/pains';
import { services } from '../data/services';
import BaseLayout from '../layouts/BaseLayout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: site.brandName,
  url: 'https://ancora.com.bo',
  logo: 'https://ancora.com.bo/favicon.svg',
  description: site.tagline,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address,
    addressCountry: 'BO',
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: site.phone,
      contactType: 'customer service',
      areaServed: 'BO',
      availableLanguage: ['Spanish'],
    },
  ],
  email: site.email,
};

const ctaAsesoria = whatsappLink('solicitarAsesoria');
const ctaWhatsApp = whatsappLink('general');

const sectionHeading =
  'uppercase tracking-wider underline decoration-accent-500 decoration-2 underline-offset-4';

// FAQ copy from Slide 4 reference. Answers are concise placeholders.
const faqItems = [
  {
    q: '¿Qué pasa si el inquilino se atrasa?',
    a: 'Gestionamos la cobranza desde el primer día de atraso y te mantenemos informado en cada paso.',
  },
  {
    q: '¿Quién paga los mantenimientos?',
    a: 'Coordinamos los mantenimientos con proveedores confiables y gestionamos el pago según lo acordado en el contrato.',
  },
  {
    q: '¿Cómo seleccionan a los inquilinos?',
    a: 'Verificamos ingresos, referencias y documentación antes de recomendar un inquilino.',
  },
  {
    q: '¿Cada cuánto recibo mi dinero?',
    a: 'Recibís la transferencia mensual junto con un reporte detallado de ingresos y egresos.',
  },
  {
    q: '¿Trabajan con casas y departamentos?',
    a: 'Sí, administramos propiedades residenciales en alquiler, ya sean casas o departamentos.',
  },
  {
    q: '¿Hay permanencia mínima?',
    a: 'No exigimos permanencia mínima a los propietarios. El contrato se ajusta a tus necesidades.',
  },
];
---

<BaseLayout page="home" jsonLd={jsonLd}>
  {/* Hero — full-width background image, text left-aligned like reference */}
  <section
    id="hero"
    class="relative flex min-h-[640px] items-center scroll-mt-20 bg-primary-600 text-white"
  >
    {/* TODO(PR 4): replace with NanoBanana lifestyle photo */}
    <div class="absolute inset-0">
      <img
        src="https://picsum.photos/seed/ancora-hero/1440/800"
        alt=""
        class="h-full w-full object-cover"
        width="1440"
        height="800"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-600/95 via-primary-600/80 to-primary-600/30"></div>
    </div>

    <div class="relative mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h1 class="font-display text-5xl font-bold leading-tight sm:text-6xl lg:text-7xl">
          Tu propiedad genera renta.
          <span class="block text-accent-500">Vos solo cobrás.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-neutral-100 sm:text-xl">
          Administramos íntegramente tu inmueble para que generes ingresos sin ocuparte del día a día.
        </p>
        <div class="mt-8">
          <a
            href={ctaAsesoria}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-6 py-3 text-base font-semibold text-primary-600 transition-colors hover:bg-accent-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
          >
            <Icon name="ph:whatsapp-logo" aria-hidden="true" />
            Solicitar asesoría gratuita
          </a>
        </div>
      </div>

      <TrustStrip />
    </div>
  </section>

  {/* Dolores */}
  <Section
    id="dolores"
    background="muted"
  >
    <div class="max-w-3xl">
      <h2 class:list={['font-display text-3xl font-semibold leading-tight sm:text-4xl text-primary-600', sectionHeading]}>
        ¿Compraste un inmueble para generar ingresos o para administrar problemas?
      </h2>
      <p class="mt-4 text-lg text-neutral-600">
        Muchos propietarios terminan ocupándose de tareas que les quitan tiempo, dinero y tranquilidad.
      </p>
    </div>
    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-5">
      {pains.map((pain) => <PainCard pain={pain} />)}
    </div>
  </Section>

  {/* Cómo funciona */}
  <Section
    id="como-funciona"
    heading="COMO FUNCIONA?"
    headingClass={sectionHeading}
    intro="Nos ocupamos de todo el proceso, de principio a fin."
    background="default"
  >
    <ProcessCycle />
  </Section>

  {/* Servicios */}
  <Section
    id="servicios"
    background="muted"
  >
    <div class="max-w-3xl">
      <h2 class:list={['font-display text-3xl font-semibold leading-tight sm:text-4xl text-primary-600', sectionHeading]}>
        SERVICIOS
      </h2>
      <p class="mt-2 text-lg font-semibold text-primary-600">¿QUÉ INCLUYE NUESTRO SERVICIO?</p>
      <p class="mt-4 text-lg text-neutral-600">
        Administración integral para proteger tu patrimonio y maximizar tu rentabilidad.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <ServiceCard
          title={service.title}
          description={service.description}
          icon={service.icon}
        />
      ))}
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <MonthlyReport />
      <PricingCard />
    </div>
  </Section>

  {/* Diferenciación */}
  <Section
    id="diferenciacion"
    heading="La Diferencia entre Alquilar y Administrar"
    intro="Muchas inmobiliarias terminan su trabajo cuando se firma el contrato. ANCORA continúa administrando durante toda la relación contractual."
    background="default"
  >
    <ComparisonVisual />
  </Section>

  {/* FAQ */}
  <Section
    id="preguntas"
    heading="PREGUNTAS FRECUENTES"
    headingClass={sectionHeading}
    intro="Respuestas a las dudas más comunes de los propietarios."
    background="muted"
  >
    <FaqAccordion items={faqItems} />
  </Section>

  {/* CTA final */}
  <section
    id="cta-final"
    class="relative flex min-h-[480px] items-center scroll-mt-20 bg-primary-600 text-white"
  >
    {/* TODO(PR 4): replace with NanoBanana building dusk photo */}
    <div class="absolute inset-0">
      <img
        src="https://picsum.photos/seed/ancora-building/1440/800"
        alt=""
        class="h-full w-full object-cover"
        width="1440"
        height="800"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary-600/95 via-primary-600/80 to-primary-600/30"></div>
    </div>

    <div class="relative mx-auto w-full max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <h2 class="font-display text-3xl font-semibold text-white sm:text-4xl">
          Tu patrimonio merece administración profesional.
        </h2>
        <p class="mt-4 max-w-xl text-lg text-neutral-200">
          Nos encargamos de todo para que vos solo disfrutes los resultados.
        </p>
        <div class="mt-8 flex flex-col items-start gap-3 sm:flex-row">
          <a
            href={ctaAsesoria}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-accent-500 px-6 py-3 text-base font-semibold text-primary-600 transition-colors hover:bg-accent-400 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500"
          >
            <Icon name="ph:calendar-check" aria-hidden="true" />
            Agendar asesoría gratuita
          </a>
          <a
            href={ctaWhatsApp}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-md border border-white px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
          >
            <Icon name="ph:phone" aria-hidden="true" />
            Escribinos por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
