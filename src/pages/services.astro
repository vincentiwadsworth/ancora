---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProcessStep from '../components/ProcessStep.astro';
import SegmentedCta from '../components/SegmentedCta.astro';
import { services } from '../data/services';
import { tenantSelectionSteps } from '../data/tenantSelectionSteps';
import { protectionMeasures } from '../data/protectionMeasures';
import { pricing } from '../data/pricing';
---

<BaseLayout page="services">
  <Section
    id="introduccion"
    containerClass="!py-[var(--spacing-section-y-sm)]"
    background="default"
  >
    <div class="max-w-3xl">
      <h1 class="text-4xl font-bold leading-tight text-primary-600 sm:text-5xl">
        ¿Qué es ANCORA?
      </h1>
      <p class="mt-6 text-lg text-neutral-600 sm:text-xl">
        ANCORA es una empresa especializada en la administración integral de
        propiedades residenciales. Nos encargamos de todo el proceso para que
        tu inmueble genere rentabilidad sin que tengas que ocuparte del día a
        día.
      </p>
    </div>
  </Section>

  <Section
    id="servicios"
    heading="Nuestros servicios"
    intro="Cobertura completa: desde la captación hasta la entrega del inmueble."
    background="muted"
  >
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <ServiceCard title={service.title} description={service.description} />
      ))}
    </div>
  </Section>

  <Section
    id="proceso-seleccion"
    heading="Nuestro proceso de selección de inquilinos"
    intro="Evaluamos antes de recomendar — reducimos el riesgo antes de firmar."
    background="default"
  >
    <div class="mx-auto max-w-3xl">
      {tenantSelectionSteps.map((step) => (
        <ProcessStep step={step} />
      ))}
    </div>
    <p class="mt-8 text-base italic text-neutral-600">
      Objetivo: reducir el riesgo antes de firmar. Un buen inquilino vale más
      que el primer interesado.
    </p>
  </Section>

  <Section
    id="proteccion"
    heading="Protegemos el estado de tu inversión"
    intro="Documentamos todo para que tengas respaldo en cualquier circunstancia."
    background="muted"
  >
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      {protectionMeasures.map((measure) => (
        <ServiceCard title={measure.title} description={measure.description} icon="shield" />
      ))}
    </div>
    <p class="mt-10 text-base italic text-neutral-600">
      Tu inmueble tiene valor. Nosotros lo preservamos.
    </p>
  </Section>

  <Section
    id="precio"
    heading="¿Cuánto cuesta?"
    intro={pricing.statement}
    background="default"
  >
    <div class="mx-auto max-w-3xl rounded-lg border border-neutral-200 bg-white p-8 sm:p-12">
      <p class="text-5xl font-bold text-primary-600 sm:text-6xl">7%</p>
      <p class="mt-2 text-lg text-neutral-600">
        {pricing.rate}
      </p>

      <div class="mt-10 border-t border-neutral-200 pt-8">
        <p class="text-sm font-semibold uppercase tracking-wider text-neutral-500">
          Ejemplo — Alquiler de {pricing.example.rent}:
        </p>
        <dl class="mt-6 space-y-3 text-base">
          <div class="flex items-baseline justify-between">
            <dt class="text-neutral-600">Canon cobrado</dt>
            <dd class="font-semibold text-primary-600">{pricing.example.rent}</dd>
          </div>
          <div class="flex items-baseline justify-between">
            <dt class="text-neutral-600">Fee Ancora (7%)</dt>
            <dd class="font-semibold text-neutral-500">– {pricing.example.fee}</dd>
          </div>
          <div class="flex items-baseline justify-between border-t border-neutral-200 pt-3">
            <dt class="font-semibold text-primary-600">Vos recibís</dt>
            <dd class="text-xl font-bold text-primary-600">{pricing.example.net}</dd>
          </div>
        </dl>
      </div>

      <p class="mt-8 text-sm italic text-neutral-500">
        {pricing.disclaimer}
      </p>
    </div>

    <div class="mx-auto mt-10 flex max-w-3xl flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-center">
      <SegmentedCta intent="evaluate" variant="primary" />
      <SegmentedCta intent="general" variant="secondary" />
      <SegmentedCta intent="process" variant="ghost" />
    </div>
  </Section>
</BaseLayout>
